# Lake root. Use a local path for dev, an s3:// URI for prod.
#   local dev:  ./data/lake
#   s3:         s3://my-bucket/finpulse/lake
FINPULSE_LAKE_ROOT=./data/lake

# Per-batch flush thresholds. Smaller = more files, lower latency. Larger = fewer files, higher latency.
FINPULSE_BATCH_MAX_EVENTS=500
FINPULSE_BATCH_MAX_SECONDS=30

# How often each ingester polls upstream (seconds).
FINPULSE_POLL_INTERVAL=2.0

# Logging: text (human) or json (production)
FINPULSE_LOG_FORMAT=text
FINPULSE_LOG_LEVEL=INFO
